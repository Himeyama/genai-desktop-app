<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="WebHostDesktopApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:WebHostDesktopApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="玄海"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <!-- WebUIをウィンドウ全体に広げる -->
        <WebView2 x:Name="MyWebView" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

        <!-- ウィンドウをドラッグ移動するための透明な領域を上部に重ねる -->
        <Grid x:Name="AppTitleBar" Height="60" VerticalAlignment="Top" Background="Transparent" />
    </Grid>
</Window>
